{
  "name": "armin/open-ai-device-auth",
  "description": "OpenAI device code authentication CLI for ChatGPT tokens.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "symfony/console": "^7.4 || ^8.0",
    "symfony/filesystem": "^7.4 || ^8.0",
    "symfony/http-client": "^7.4 || ^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "Armin\\OpenAiDeviceAuth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Armin\\OpenAiDeviceAuth\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/open-ai-device-auth"
  ],
  "scripts": {
    "test": "phpunit"
  }
}
