#!/usr/bin/env php
<?php

declare(strict_types=1);

use Armin\OpenAiDeviceAuth\Command\OpenAiDeviceAuthCommand;
use Symfony\Component\Console\Application;

require dirname(__DIR__) . '/vendor/autoload.php';

$application = new Application('open-ai-device-auth');
$application->addCommand(new OpenAiDeviceAuthCommand());
$application->setDefaultCommand(OpenAiDeviceAuthCommand::NAME, true);

exit($application->run());
